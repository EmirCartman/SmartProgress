# ─────────────────────────────────────────────
# SmartProgress — Backend Environment Variables
# ─────────────────────────────────────────────
# Bu dosyayı .env olarak kopyalayıp değerleri güncelleyiniz.

NODE_ENV=development
PORT=3000

# PostgreSQL
DATABASE_URL=postgresql://smartprogress:smartprogress_secret@localhost:5432/smartprogress_db?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# JWT (sonraki aşamada kullanılacak)
# JWT_SECRET=your-super-secret-jwt-key
# JWT_EXPIRES_IN=7d
